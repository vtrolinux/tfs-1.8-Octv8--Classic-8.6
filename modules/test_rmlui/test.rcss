body {
  display: block;
  width: 100%;
  height: 100%;
}

#window {
  position: absolute;
  top: 50px;
  left: 50px;
  width: 420px;
  height: 260px;
  background-color: #6a0dad;
  padding: 20px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-family: Maferic;
}

h1 {
  display: block;
  color: #ffffff;
  font-size: 24px;
  margin-bottom: 20px;
  text-align: center;
}

#click-label {
  display: block;
  color: #e0b0ff;
  font-size: 20px;
  margin-bottom: 20px;
  text-align: center;
}

#click-btn {
  display: inline-block;
  background-color: #9b30ff;
  color: #ffffff;
  font-size: 18px;
  padding: 12px 32px;
  border: 2px #d8a0ff;
  margin-bottom: 20px;
  text-align: center;
  cursor: pointer;
}

#click-btn:hover {
  background-color: #b060ff;
}

#click-btn:active {
  background-color: #7a20cc;
}

#text-input {
  display: inline-block;
  width: 280px;
  height: 30px;
  font-size: 14px;
  padding: 4px 8px;
  background-color: #ffffff;
  color: #333333;
  border: 2px #d8a0ff;
  box-sizing: border-box;
}
