    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 6
    width: 50

  UIWidget
    id: speedAmountIcon
    image-source: /images/game/bestiary/haste
    anchors.top: experienceAmountIcon.bottom
    anchors.left: experienceAmountIcon.left
    margin-top: 10

  Label
    id: speedAmount
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 6
    width: 50

  UIWidget
    id: armorAmountIcon
    image-source: /images/game/bestiary/armor
    anchors.top: speedAmountIcon.bottom
    anchors.left: speedAmountIcon.left
    margin-top: 10

  Label
    id: armorAmount
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 6
    width: 50

  UIWidget
