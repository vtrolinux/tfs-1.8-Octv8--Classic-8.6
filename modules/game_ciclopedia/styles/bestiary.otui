    background-color: #18ce18

  UIWidget
    id: deathAmountContainer
    image-source: /images/game/bestiary/elementContainer
    anchors.verticalCenter: deathIcon.verticalCenter
    anchors.left: deathIcon.right
    margin-left: 3

  UIWidget
    id: energyIcon
    image-source: /images/game/bestiary/energy
    anchors.top: physicalIcon.bottom
    anchors.left: physicalIcon.left
    margin-top: 12

  UIProgressBar
    id: energyAmount
    anchors.top: next.top
    anchors.bottom: next.bottom
    anchors.left: next.left
    anchors.right: next.right
    margin-top: 1
    margin-bottom: 2
    background-color: #18ce18

  UIWidget
    id: energyAmountContainer
    image-source: /images/game/bestiary/elementContainer
    anchors.verticalCenter: energyIcon.verticalCenter
    anchors.left: energyIcon.right
    margin-left: 3

  UIWidget
    id: holyIcon
    image-source: /images/game/bestiary/holy
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 6

  UIProgressBar
    id: holyAmount
    anchors.top: next.top
    anchors.bottom: next.bottom
    anchors.left: next.left
    anchors.right: next.right
    margin-top: 1
    margin-bottom: 2
    background-color: #18ce18

  UIWidget
    id: holyAmountContainer
