  Label
    text: Location(s):
    font: verdana-11px-rounded
    anchors.top: energyIcon.bottom
    anchors.left: energyIcon.left
    margin-top: 13

  ScrollablePanel
    id: locationField
    background-color: #363636
    anchors.top: prev.bottom
    anchors.left: prev.left
    size: 318 105
    margin-top: 6
    vertical-scrollbar: verticalLocationSB
    border-color: #161616
    border-width-top: 1
    border-width-left: 1
    border-width-bottom: 1
    border-width-right: 1

    Label
      id: locationTextfield
      font: verdana-9px
      anchors.top: parent.top
      anchors.left: parent.left
      anchors.right: parent.right
      margin-top: 4
      margin-left: 5
      margin-right: 15
      text-wrap: true
      text-auto-resize: true
      text-align: left

  VerticalScrollBar
    id: verticalLocationSB
    anchors.top: locationField.top
    anchors.bottom: locationField.bottom
    anchors.right: locationField.right
    margin-top: 1
    margin-bottom: 1
    step: 12
    pixels-scroll: true

