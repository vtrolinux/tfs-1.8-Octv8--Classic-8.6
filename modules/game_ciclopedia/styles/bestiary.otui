    anchors.verticalCenter: holyIcon.verticalCenter
    anchors.left: holyIcon.right
    margin-left: 3

  UIWidget
    id: iceIcon
    image-source: /images/game/bestiary/ice
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 6

  UIProgressBar
    id: iceAmount
    anchors.top: next.top
    anchors.bottom: next.bottom
    anchors.left: next.left
