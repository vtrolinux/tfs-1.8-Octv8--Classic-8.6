    border-width-left: 1
    border-width-bottom: 1
    border-width-right: 1

BestiaryCategory < UIWidget
  font: verdana-11px-antialised
  opacity: 1
  color: #909090
  text-offset: 0 1
  text-align: top
  margin-top: 2
  margin-left: 6
  image-source: /images/game/bestiary/window
  image-border: 4 
  image-border-top: 4

  UIWidget
    id: bestiaryContainer
    size: 64 64
    padding: 1
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: 20
    margin-left: 0
    image-source: /images/modern_ui/panel_built
    font: verdana-11px-rounded
    border-color: white
    color: white

    $pressed:
      margin-top: 21
      margin-left: 1

    UICreature
      id: creature
      size: 48 48
      anchors.verticalCenter: parent.verticalCenter
      anchors.horizontalCenter: parent.horizontalCenter
      margin-top: 0
      margin-left: 0

      $pressed:
        margin-top: 1
        margin-left: 1

    UIWidget
      id: hideCreature
      anchors.verticalCenter: parent.verticalCenter
      anchors.horizontalCenter: parent.horizontalCenter
      image-source: /images/game/bestiary/lockedCreature

  Label
    id: creatureProgress
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: 88
    color: #c0c0c0

  UIWidget
    id: creatureProgressCheck
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    image-source: /images/game/bestiary/creatureCheck
    margin-top: 88

  Label
    id: monsterId

BestiaryCategoryList < UIWidget
  font: verdana-11px-antialised
  opacity: 1
  color: #909090
  text-offset: 0 1
  text-align: top
  margin-top: 2
  margin-left: 6
  image-source: /images/game/bestiary/window
  image-border: 4 
  image-border-top: 4

  UIWidget
    id: bestiaryContainer
    size: 64 64
    padding: 1
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: 20
    margin-left: 0
    image-source: /images/modern_ui/panel_built
    font: verdana-11px-rounded
    border-color: white
    color: white

    $pressed:
      border-color: black
      color: black
      margin-top: 21
      margin-left: 1

    UIWidget
      id: bestiaryImage
      anchors.verticalCenter: parent.verticalCenter
      anchors.horizontalCenter: parent.horizontalCenter
      margin-top: 0
      margin-left: 0

      $pressed:
        margin-top: 1
        margin-left: 1

  Label
    id: totalAmount
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: 85
    color: #c0c0c0

  Label
    id: knownAmount
    anchors.top: prev.bottom
    anchors.horizontalCenter: parent.horizontalCenter
    color: #c0c0c0

  Label
    id: categoryId

UIWidget
  size: 668 452
  visible: false
  margin-left: 0

  UIWidget
    id: bestiaryContainer
    size: 668 390
    opacity: 1
    image-source: /images/modern_ui/black_border
    text-align: top
    image-border: 6
    image-border-top: 15
    anchors.top: parent.top
    anchors.left: parent.left

    UIScrollArea
      id: bestiaryCSelecter
      anchors.top: parent.top
      anchors.bottom: parent.bottom
      anchors.left: parent.left
      anchors.right: parent.right
      margin-top: 1
      margin-bottom: 1
      margin-left: 1
      margin-right: 13
      vertical-scrollbar: scrollList
      layout: verticalBox
      padding: 1
      auto-focus: none
      layout:
        type: grid
        cell-size: 126 119
        flow: true
        auto-spacing: true

    VerticalScrollBar
      id: scrollList
      anchors.top: bestiaryCSelecter.top
      anchors.bottom: bestiaryCSelecter.bottom
      anchors.left: bestiaryCSelecter.right
      step: 158
      pixels-scroll: true

  Button
    id: closeButton
    size: 43 20
    anchors.bottom: parent.bottom
    anchors.right: parent.right
    !text: tr('Close')
    font: cipsoftFont
    @onClick: modules.game_ciclopedia.toggle()

  Button
    id: backButton
    size: 43 20
    anchors.bottom: parent.bottom
    anchors.right: prev.left
    !text: tr('Back')
    font: cipsoftFont
    margin-right: 6
    @onClick: modules.game_ciclopedia.requestBestiaryData()

  HorizontalSeparator
    id: horizontalSeparator
    anchors.bottom: prev.top
    anchors.left: parent.left
    anchors.right: parent.right
    margin-bottom: 12

  UIWidget
    id: blackBG01
    image-source: /images/modern_ui/image3498397
    size: 104 20
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    margin-bottom: 1

    UIWidget
      id: goldIcon
      image-source: /images/modern_ui/gold
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      margin-bottom: 5
      margin-right: 3

    Label
      id: goldPoints
      text-align: right
      anchors.bottom: parent.bottom
      anchors.right: prev.left
      margin-bottom: 2
      margin-right: 2

  UIWidget
    id: blackBG02
    image-source: /images/modern_ui/image3498397
    size: 104 20
    anchors.bottom: parent.bottom
    anchors.left: prev.right
    margin-left: 6
    margin-bottom: 1

    UIWidget
      id: charmIcon
      image-source: /images/modern_ui/charm_big
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      margin-bottom: 3
      margin-right: 3

    Label
      id: charmPoints
      text-align: right
      anchors.bottom: parent.bottom
      anchors.right: prev.left
      margin-bottom: 2
      margin-right: 2
      width: 80

  Button
    id: bestiaryTracker
    size: 86 20
    text: Bestiary Tracker
    font: cipsoftFont
    anchors.bottom: parent.bottom
    anchors.left: prev.right
    margin-left: 6
    margin-bottom: 1

  Button
    id: searchButton
    size: 43 20
    text: Search
    font: cipsoftFont
    anchors.bottom: horizontalSeparator.bottom
    anchors.right: horizontalSeparator.right
    margin-bottom: 7

  TextEdit
    id: searchInput
    anchors.verticalCenter: searchButton.verticalCenter
    anchors.right: prev.left
    margin-right: 5
    size: 150 16
