BestiaryMonster < UIWidget
  id: bestiaryMonster
  anchors.top: parent.top
  anchors.left: parent.left
  font: verdana-11px-antialised
  size: 668 390
  color: #909090
  text-offset: 0 6
  text-align: top
  image-source: /images/modern_ui/window
  image-border: 6
  image-border-top: 27
  border-color: #000000
  border-width-top: 1
  border-width-left: 1
  border-width-bottom: 1
  border-width-right: 1

  UICreature
    id: bestiaryCreature
    size: 96 96
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 40
    margin-left: 25

  Label
    anchors.top: parent.top
    anchors.left: prev.right
    margin-top: 25
    margin-left: 90
    text: Total Kills
    font: verdana-11px-rounded

  UIWidget
    id: progressBarImage
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    image-source: /images/game/bestiary/bestiaryContainer
    margin-top: 39
    margin-right: 96

  UIProgressBar
    id: progressBar
    anchors.top: progressBarImage.top
    anchors.bottom: progressBarImage.bottom
    anchors.left: progressBarImage.left
    anchors.right: progressBarImage.right
    background-color: #1b7400
    border: 1 black
    height: 5
    phantom: false

  UIWidget
    id: totalKillsLabel
    anchors.verticalCenter: progressBarImage.verticalCenter
    anchors.horizontalCenter: progressBarImage.horizontalCenter
    image-source: /images/game/bestiary/bestiaryContainerBorder
    text: 1

  UIWidget
    id: starsContainer
    size: 60 10
    anchors.top: progressBarImage.bottom
    anchors.left: progressBarImage.left
    margin-top: 9

    BestiaryStars
      id: stars1

    BestiaryStars
      id: stars2
      anchors.left: prev.right
      margin-left: 3

    BestiaryStars
      id: stars3
      anchors.left: prev.right
      margin-left: 3

    BestiaryStars
      id: stars4
      anchors.left: prev.right
      margin-left: 3

    BestiaryStars
      id: stars5
      anchors.left: prev.right
      margin-left: 3

  UIWidget
    id: occurrenceContainer
    size: 60 10
    anchors.top: prev.bottom
    anchors.left: prev.left
    margin-top: 6

    BestiaryOccurrence
      id: occurrence1

    BestiaryOccurrence
      id: occurrence2
      anchors.left: prev.right
      margin-left: 3

    BestiaryOccurrence
      id: occurrence3
      anchors.left: prev.right
      margin-left: 3

    BestiaryOccurrence
      id: occurrence4
      anchors.left: prev.right
      margin-left: 3

  Label
    id: typeContainer
    text: ?
    anchors.top: prev.bottom
    anchors.left: prev.left
    margin-top: 6

  UIWidget
    id: charmAmountIcon
    image-source: /images/game/bestiary/charm
    anchors.top: prev.bottom
    anchors.left: prev.left
    margin-top: 7

  Label
    id: charmAmount
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 6
    width: 50

  VerticalSeparator
    id: verticalSeparator01
    anchors.top: starsContainer.top
    anchors.bottom: charmAmount.bottom
    anchors.left: charmAmount.right
    margin-top: -4
    margin-bottom: -2
    margin-left: 60

  UIWidget
    id: healthAmountIcon
    image-source: /images/game/bestiary/health
    anchors.top: prev.top
    anchors.left: prev.right
    margin-top: 3
    margin-left: 6

  Label
    id: healthAmount
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 6
    width: 50

  UIWidget
    id: experienceAmountIcon
    image-source: /images/game/bestiary/exp
    anchors.top: healthAmountIcon.bottom
    anchors.left: healthAmountIcon.left
    margin-top: 10

  Label
