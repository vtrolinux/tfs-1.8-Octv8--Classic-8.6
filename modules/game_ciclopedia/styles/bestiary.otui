    margin-bottom: 2
    background-color: #18ce18

  UIWidget
    id: iceAmountContainer
    image-source: /images/game/bestiary/elementContainer
    anchors.verticalCenter: iceIcon.verticalCenter
    anchors.left: iceIcon.right
    margin-left: 3

  UIWidget
    id: healingIcon
    image-source: /images/game/bestiary/plus
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 6

  UIProgressBar
    id: healingAmount
    anchors.top: next.top
    anchors.bottom: next.bottom
    anchors.left: next.left
    anchors.right: next.right
