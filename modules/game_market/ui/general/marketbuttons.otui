MarketButtonBox < ButtonBoxRounded
  font: verdana-11px-rounded
  color: #f55e5ebb
  size: 106 22
  text-offset: 0 2
  text-align: center

  $!checked:
    color: #f55e5ebb

  $hover !checked:
    color: #ff7777ff

  $checked:
    color: white

  $disabled:
    color: #666666ff
    image-color: #ffffff88
