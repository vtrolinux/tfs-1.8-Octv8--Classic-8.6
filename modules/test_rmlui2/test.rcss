body {
  display: block;
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

#window {
  position: absolute;
  top: 80px;
  left: 80px;
  width: 460px;
  height: 300px;
  background-color: #2b2b2b;
  padding: 16px;
  box-sizing: border-box;
  font-family: Maferic;
}

#title {
  display: block;
  width: 420px;
  height: 22px;
  margin-top: 4px;
  margin-bottom: 12px;
  background-color: #8b00ff;
  color: #ffffff;
  font-size: 14px;
  text-align: center;
}

#status-box {
  display: block;
  width: 390px;
  height: 74px;
  margin-left: 14px;
  margin-bottom: 12px;
  padding: 10px;
  background-color: #5a0099;
  border: 1px #5a5a5a;
  box-sizing: border-box;
}

#statusLabel {
  display: block;
  height: 24px;
  background-color: #7a00cc;
  color: #ffffff;
  font-size: 13px;
  text-align: center;
}

#counterLabel {
  display: block;
  margin-top: 8px;
  height: 24px;
  background-color: #7a00cc;
  color: #d8e0ff;
  font-size: 13px;
  text-align: center;
}

#clickButton {
  display: block;
  width: 160px;
  height: 28px;
  margin-left: 120px;
  margin-top: 10px;
  background-color: #9b30ff;
  color: #ffffff;
  font-size: 13px;
  text-align: center;
  border: 1px #7a20cc;
}

#clickButton:hover {
  background-color: #b060ff;
  color: #ffffff;
}

#clickButton:active {
  background-color: #7a20cc;
}

#closeButton {
  display: block;
  width: 80px;
  height: 24px;
  margin-left: 160px;
  margin-top: 8px;
  background-color: #444444;
  color: #cccccc;
  font-size: 11px;
  text-align: center;
  border: 1px #555555;
}

#closeButton:hover {
  background-color: #666666;
  color: #ffffff;
}

#closeButton:active {
  background-color: #333333;
}
